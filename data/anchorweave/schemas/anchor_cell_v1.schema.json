{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vraxion.local/schemas/anchor_cell_v1.schema.json",
  "title": "AnchorWeave AnchorCell v1.0",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "cell_id",
    "revision",
    "created_at",
    "provenance",
    "episode",
    "relational_graph",
    "salience",
    "actions",
    "outcomes",
    "counterfactuals",
    "memory_hooks",
    "abstraction",
    "symbol_binding",
    "human_annotation",
    "outcome_followup"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "AnchorWeave-v1.0"
    },
    "cell_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9_.:-]+$"
    },
    "revision": {
      "type": "integer",
      "minimum": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "provenance": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "source",
        "author",
        "privacy_tier",
        "collection_method",
        "contains_private_data"
      ],
      "properties": {
        "source": {
          "type": "string"
        },
        "author": {
          "type": "string"
        },
        "privacy_tier": {
          "type": "string"
        },
        "collection_method": {
          "type": "string"
        },
        "contains_private_data": {
          "type": "boolean"
        },
        "sanitization": {
          "type": "string"
        }
      }
    },
    "episode": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "domain",
        "title",
        "scene",
        "temporal_context",
        "entities",
        "cues"
      ],
      "properties": {
        "domain": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string"
        },
        "scene": {
          "type": "string",
          "minLength": 1
        },
        "temporal_context": {
          "type": "string"
        },
        "entities": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/entity"
          }
        },
        "cues": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/cue"
          }
        }
      }
    },
    "relational_graph": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "nodes",
        "edges"
      ],
      "properties": {
        "nodes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/graph_node"
          }
        },
        "edges": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/graph_edge"
          }
        }
      }
    },
    "salience": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "high",
        "medium",
        "low"
      ],
      "properties": {
        "high": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/salience_item"
          }
        },
        "medium": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/salience_item"
          }
        },
        "low": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/salience_item"
          }
        }
      }
    },
    "actions": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "available",
        "taken"
      ],
      "properties": {
        "available": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/action"
          }
        },
        "taken": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/action_taken"
          }
        }
      }
    },
    "outcomes": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "predicted",
        "actual"
      ],
      "properties": {
        "predicted": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/outcome"
          }
        },
        "actual": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/outcome"
          }
        }
      }
    },
    "counterfactuals": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/counterfactual"
      }
    },
    "memory_hooks": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/memory_hook"
      }
    },
    "abstraction": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "level",
        "pre_symbol_statement",
        "claim_boundary",
        "not_this"
      ],
      "properties": {
        "level": {
          "type": "string",
          "enum": [
            "raw_episode",
            "episodic_affordance",
            "causal_relation",
            "outcome_pattern",
            "cross_domain_abstraction",
            "symbol_binding"
          ]
        },
        "pre_symbol_statement": {
          "type": "string"
        },
        "claim_boundary": {
          "type": "string"
        },
        "not_this": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "symbol_binding": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "attach",
        "reject"
      ],
      "properties": {
        "attach": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/symbol_decision"
          }
        },
        "reject": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/symbol_decision"
          }
        }
      }
    },
    "human_annotation": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "grounding_judgment",
        "confidence",
        "best_summary",
        "error_tags",
        "positive_tags",
        "claim_boundary"
      ],
      "properties": {
        "grounding_judgment": {
          "type": "string",
          "enum": [
            "valid_anchor",
            "weak_anchor",
            "invalid_anchor",
            "ambiguous_anchor"
          ]
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "best_summary": {
          "type": "string"
        },
        "error_tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "positive_tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "claim_boundary": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "outcome_followup": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "status",
        "required_followup",
        "observations"
      ],
      "properties": {
        "status": {
          "type": "string"
        },
        "required_followup": {
          "type": "boolean"
        },
        "observations": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/outcome_followup_observation"
          }
        }
      }
    },
    "candidate_outputs": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    }
  },
  "$defs": {
    "entity": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "id",
        "type",
        "label"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "type": {
          "type": "string"
        },
        "label": {
          "type": "string"
        }
      }
    },
    "cue": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "cue",
        "observed",
        "role"
      ],
      "properties": {
        "cue": {
          "type": "string"
        },
        "observed": {
          "type": "string"
        },
        "role": {
          "type": "string"
        }
      }
    },
    "graph_node": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "id",
        "type",
        "label"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "type": {
          "type": "string"
        },
        "label": {
          "type": "string"
        }
      }
    },
    "graph_edge": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "source",
        "target",
        "relation"
      ],
      "properties": {
        "source": {
          "type": "string"
        },
        "target": {
          "type": "string"
        },
        "relation": {
          "type": "string"
        },
        "evidence": {
          "type": "string"
        },
        "salience_weight": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    },
    "salience_item": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "item",
        "reason"
      ],
      "properties": {
        "item": {
          "type": "string"
        },
        "reason": {
          "type": "string"
        },
        "entity_refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "action": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "action_id",
        "description"
      ],
      "properties": {
        "action_id": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "available_to": {
          "type": "string"
        }
      }
    },
    "action_taken": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "action_id",
        "description",
        "outcome_ref"
      ],
      "properties": {
        "action_id": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "outcome_ref": {
          "type": "string"
        }
      }
    },
    "outcome": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "outcome_id",
        "summary"
      ],
      "properties": {
        "outcome_id": {
          "type": "string"
        },
        "action_id": {
          "type": "string"
        },
        "summary": {
          "type": "string"
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "evidence": {
          "type": "string"
        }
      }
    },
    "counterfactual": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "condition",
        "expected_change",
        "anchor_test"
      ],
      "properties": {
        "condition": {
          "type": "string"
        },
        "expected_change": {
          "type": "string"
        },
        "anchor_test": {
          "type": "string"
        }
      }
    },
    "memory_hook": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "hook",
        "type",
        "why_it_matters"
      ],
      "properties": {
        "hook": {
          "type": "string"
        },
        "type": {
          "type": "string"
        },
        "why_it_matters": {
          "type": "string"
        }
      }
    },
    "symbol_decision": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "symbol",
        "score",
        "rationale"
      ],
      "properties": {
        "symbol": {
          "type": "string"
        },
        "score": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "rationale": {
          "type": "string"
        }
      }
    },
    "outcome_followup_observation": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "timestamp",
        "observation"
      ],
      "properties": {
        "timestamp": {
          "type": "string"
        },
        "observation": {
          "type": "string"
        }
      }
    }
  }
}
