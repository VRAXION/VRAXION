{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/VRAXION/VRAXION/main/releases/public-release-manifest.schema.json",
  "title": "VRAXION Public Release Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "release_slug",
    "release_date",
    "release_kind",
    "public_claim",
    "source_of_truth",
    "public_files",
    "artifacts",
    "exclusions",
    "verification"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "schema": {
      "const": "vraxion.public.release-manifest.v1"
    },
    "release_slug": {
      "type": "string",
      "pattern": "^public-[a-z0-9][a-z0-9-]*-[0-9]{8}$"
    },
    "release_date": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
    },
    "release_kind": {
      "type": "string",
      "enum": [
        "docs_only",
        "sdk_docs",
        "proof_pack",
        "artifact_release"
      ]
    },
    "public_claim": {
      "type": "string",
      "minLength": 1,
      "maxLength": 500
    },
    "source_of_truth": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "version_file",
        "github_release",
        "status_docs"
      ],
      "properties": {
        "version_file": {
          "$ref": "#/$defs/repo_relative_path"
        },
        "github_release": {
          "type": "string",
          "pattern": "^https://github\\.com/VRAXION/VRAXION/releases/tag/public-[a-z0-9][a-z0-9-]*-[0-9]{8}$"
        },
        "status_docs": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/repo_relative_path"
          }
        }
      }
    },
    "public_files": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/repo_relative_path"
      }
    },
    "artifacts": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/artifact"
      }
    },
    "exclusions": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "private_engine_source",
        "non_public_training_data",
        "raw_operator_output",
        "local_machine_paths",
        "secrets_or_tokens",
        "filled_production_config",
        "private_dashboards"
      ],
      "properties": {
        "private_engine_source": {
          "const": false
        },
        "non_public_training_data": {
          "const": false
        },
        "raw_operator_output": {
          "const": false
        },
        "local_machine_paths": {
          "const": false
        },
        "secrets_or_tokens": {
          "const": false
        },
        "filled_production_config": {
          "const": false
        },
        "private_dashboards": {
          "const": false
        }
      }
    },
    "verification": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "commands",
        "github_checks",
        "reviewer"
      ],
      "properties": {
        "commands": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "github_checks": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "reviewer": {
          "type": "string",
          "pattern": "^@[A-Za-z0-9-]+$"
        }
      }
    }
  },
  "$defs": {
    "repo_relative_path": {
      "type": "string",
      "pattern": "^(?![A-Za-z]:)(?!/)(?!.*\\.\\.)(?!.*//)[A-Za-z0-9._/-]+$"
    },
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "kind",
        "status",
        "path_or_url",
        "sha256",
        "signature_path_or_url",
        "notes"
      ],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._-]+$"
        },
        "kind": {
          "type": "string",
          "enum": [
            "documentation",
            "repository_zip",
            "proof_pack",
            "checksum",
            "signature",
            "binary",
            "other"
          ]
        },
        "status": {
          "type": "string",
          "enum": [
            "published",
            "pending_review",
            "not_included"
          ]
        },
        "path_or_url": {
          "type": "string",
          "minLength": 1
        },
        "sha256": {
          "anyOf": [
            {
              "type": "string",
              "pattern": "^[a-f0-9]{64}$"
            },
            {
              "type": "null"
            }
          ]
        },
        "signature_path_or_url": {
          "anyOf": [
            {
              "type": "string",
              "minLength": 1
            },
            {
              "type": "null"
            }
          ]
        },
        "notes": {
          "type": "string",
          "maxLength": 500
        }
      }
    }
  }
}
